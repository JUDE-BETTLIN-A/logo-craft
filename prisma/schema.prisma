generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  image         String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  logos         Logo[]
  favorites     Favorite[]
  downloads     Download[]
}

model Logo {
  id              String   @id @default(cuid())
  name            String
  businessName    String
  tagline         String?
  industry        String
  style           String
  colors          String   // JSON array stored as string
  fontFamily      String
  iconName        String
  layout          String
  backgroundColor String
  textColor       String
  iconColor       String
  fontSize        Int      @default(24)
  iconSize        Int      @default(40)
  spacing         Int      @default(16)
  borderRadius    Int      @default(0)
  shadow          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  favorites       Favorite[]
  downloads       Download[]

  @@index([userId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  logoId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  logo      Logo     @relation(fields: [logoId], references: [id])

  @@unique([userId, logoId])
  @@index([userId])
}

model Download {
  id        String   @id @default(cuid())
  userId    String
  logoId    String
  format    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  logo      Logo     @relation(fields: [logoId], references: [id])

  @@index([userId])
}

// Telegram AI Sales Bot - Your connected bot account
model TelegramBot {
  id            String   @id @default(cuid())
  phoneNumber   String   @unique
  sessionString String
  apiId         Int
  apiHash       String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  leads         Lead[]
}

// Customer leads (bulk imported)
model Lead {
  id            String   @id @default(cuid())
  phoneNumber   String   @unique
  name          String?
  source        String   @default("manual")
  campaign      String?
  status        String   @default("new")
  assignedBotId String
  bot           TelegramBot @relation(fields: [assignedBotId], references: [id])
  conversations Conversation[]
  minPrice      Int      @default(49)
  maxPrice      Int      @default(199)
  finalPrice    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([campaign])
}

// Conversations with each customer
model Conversation {
  id             String   @id @default(cuid())
  leadId         String
  lead           Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  telegramChatId Int
  messages       Message[]
  status         String   @default("new")
  currentOffer   Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([leadId])
}

// Messages in conversations
model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      String
  text           String
  aiGenerated    Boolean  @default(false)
  telegramMsgId  Int?
  timestamp      DateTime @default(now())

  @@index([conversationId])
  @@index([timestamp])
}

// Negotiation configuration
model NegotiationConfig {
  id              String   @id @default(cuid())
  globalMinPrice  Int      @default(49)
  globalMaxPrice  Int      @default(499)
  initialMessage  String
  followUpMessage String?
  groqModel       String   @default("llama-3.3-70b-versatile")
  tone            String   @default("friendly_casual")
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}
